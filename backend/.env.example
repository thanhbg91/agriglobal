# AgriGlobal AI Backend Configuration

# Server Port
PORT=5000

# Choose active database engine: 'mongodb', 'postgres', 'mysql', or 'file' (local file storage - no DB setup required)
DATABASE_TYPE=file

# ==========================================
# 1. MongoDB Configuration (dạng tài liệu JSON)
# ==========================================
MONGODB_URI=mongodb://localhost:27017/agriglobal

# ==========================================
# 2. PostgreSQL Configuration (dạng bảng)
# ==========================================
# Option A: Connection URI string
PG_URI=postgresql://postgres:password@localhost:5432/agriglobal
# Option B: Individual connection params (used if PG_URI is not provided)
PG_HOST=localhost
PG_USER=postgres
PG_PASSWORD=password
PG_DATABASE=agriglobal
PG_PORT=5432

# ==========================================
# 3. MySQL Configuration (dạng bảng)
# ==========================================
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=agriglobal
MYSQL_PORT=3306
